# Copy this file to `.env` and adjust as needed.
#
# Both apps load envs from the repo root for simplicity in this exercise.
# In a real setup you'd usually have one .env per app — feel free to refactor.

# ---- Web (Next.js) ----------------------------------------------------------

# Where the SQLite file lives. Defaults to apps/web/.data/habits.sqlite.
DATABASE_PATH=apps/web/.data/habits.sqlite

# Token required for destructive admin endpoints (e.g. DELETE /api/habits/:id).
# Generate a fresh one for your local environment.
ADMIN_TOKEN=replace-me-with-something-random

# Origin of the admin dashboard, used for CORS allow-listing.
WEB_ORIGIN=http://localhost:3000


# ---- Mobile (Expo) ----------------------------------------------------------

# Base URL the mobile app uses to reach the API. Anything prefixed with
# EXPO_PUBLIC_ is inlined into the JS bundle at build time.
#   iOS simulator:    http://localhost:3000
#   Android emulator: http://10.0.2.2:3000
#   Physical device:  http://<your-LAN-IP>:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
